# Last FM Environment Configuration

# Last.fm API Configuration
LASTFM_API_KEY=your_lastfm_api_key
LASTFM_SHARED_SECRET=your_shared_secret

# Server Configuration
PORT=3000

# Environment
NODE_ENV=production

# Logging
LOG_LEVEL=info

# Security
HELMET_ENABLED=true

# Optional: Database (if persisting data)
# DATABASE_URL=postgresql://user:pass@localhost:5432/lastfm

# Optional: Authentication
# AUTH_TOKEN=your_secure_token

# Feature Flags
ENABLE_CACHE=true
CACHE_TTL=3600
