# Production Environment Configuration
# Copy this file and set actual values before deployment
# NEVER commit the actual .env.production file to version control

# Last.fm API Configuration (REQUIRED)
LASTFM_API_KEY=your_production_lastfm_api_key_here
LASTFM_SHARED_SECRET=your_production_shared_secret_here

# Freesound API Configuration (OPTIONAL)
FREESOUND_API_KEY=your_production_freesound_api_key_here

# Server Configuration
NODE_ENV=production
PORT=3000
HOST=0.0.0.0

# Logging Configuration
LOG_LEVEL=info
LOG_FORMAT=json
ENABLE_ACCESS_LOG=true

# Security Configuration
HELMET_ENABLED=true
CORS_ORIGIN=https://your-domain.com
RATE_LIMIT_ENABLED=true
RATE_LIMIT_MAX=100
RATE_LIMIT_WINDOW_MS=900000

# Performance & Caching
ENABLE_CACHE=true
CACHE_TTL=3600
CACHE_MAX_SIZE=100

# Monitoring & Health Checks
ENABLE_METRICS=true
HEALTH_CHECK_ENABLED=true

# Database (if applicable)
# DATABASE_URL=postgresql://user:password@localhost:5432/lastfm

# Session & Authentication (if applicable)
# SESSION_SECRET=your_secure_random_session_secret_here
# JWT_SECRET=your_secure_random_jwt_secret_here

# External Services
# SENTRY_DSN=https://your-sentry-dsn@sentry.io/project-id
# DATADOG_API_KEY=your_datadog_api_key_here

# Feature Flags
ENABLE_EXPERIMENTAL_FEATURES=false
ENABLE_ANALYTICS=true

# Deployment Information
DEPLOYMENT_ENV=production
APP_VERSION=5.3.0
