{
  "env": {
    "node": true,
    "browser": true,
    "es2021": true
  },
  "parserOptions": {
    "ecmaVersion": 2021,
    "sourceType": "module"
  },
  "extends": ["eslint:recommended"],
  "plugins": ["security"],
  "rules": {
    "security/detect-object-injection": "warn",
    "no-unused-vars": ["error", { "argsIgnorePattern": "^_" }],
    "no-redeclare": ["error", { "builtinGlobals": false }]
  }
}
