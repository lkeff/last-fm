{
  "name": "last-fm",
  "description": "Simple, robust LastFM API client (for public data) with enhanced security features",
  "version": "5.3.0",
  "author": {
    "name": "Feross Aboukhadijeh",
    "email": "feross@feross.org",
    "url": "https://feross.org"
  },
  "security": {
    "contact": "support@traycer.ai",
    "policy": "https://traycer.ai/security-policy"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "bugs": {
    "url": "https://github.com/feross/last-fm/issues"
  },
  "repository": {
    "type": "git",
    "url": "git://github.com/feross/last-fm.git"
  },
  "homepage": "https://github.com/feross/last-fm",
  "keywords": [
    "lastfm",
    "lastfm api",
    "lastfm data",
    "music",
    "music api",
    "music data",
    "last fm",
    "last fm api",
    "last fm data",
    "public data",
    "get",
    "data",
    "api",
    "last.fm",
    "last.fm api",
    "security",
    "html-sanitization",
    "url-validation",
    "encryption",
    "afk-guard",
    "studio-rig",
    "live-rig",
    "orchestra",
    "dj-booth",
    "audio-production"
  ],
  "license": "MIT",
  "main": "index.js",
  "dependencies": {
    "@tensorflow/tfjs-node": "3.18.0",
    "axios": "^1.4.0",
    "d3": "^7.9.0",
    "dompurify": "^3.2.7",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "fluent-ffmpeg": "^2.1.3",
    "glob": "^10.5.0",
    "grpc": "1.24.11",
    "helmet": "^7.0.0",
    "keytar": "^7.9.0",
    "lamejs": "^1.2.1",
    "midi-parser-js": "^4.0.4",
    "midi-writer-js": "^3.2.1",
    "musicmetadata": "^2.0.5",
    "node-id3": "^0.2.9",
    "open": "^8.4.0",
    "peaks.js": "^3.4.2",
    "picomatch": "^3.0.2",
    "run-parallel": "^1.1.10",
    "simple-get": "^4.0.0",
    "three": "^0.170.0",
    "tonal": "^5.2.1",
    "tone": "^15.1.22",
    "uuid": "^9.0.0",
    "validator": "^13.9.0",
    "wavesurfer.js": "^7.12.6",
    "webmidi": "^3.1.16",
    "ws": "^8.14.2",
    "yauzl": "^2.10.0"
  },
  "devDependencies": {
    "@tonejs/midi": "^2.0.28",
    "dependency-check": "^4.1.0",
    "electron": "^38.2.2",
    "electron-builder": "^24.6.4",
    "eslint-plugin-security": "^1.7.1",
    "fft.js": "^4.0.4",
    "ml-matrix": "^6.12.1",
    "music-tempo": "^1.0.3",
    "npm-audit-ci": "^1.2.1",
    "snyk": "^1.109.0",
    "standard": "^17.1.2",
    "wav": "^1.0.2"
  },
  "scripts": {
    "start": "electron .",
    "dev": "electron .",
    "test:security": "eslint --ext .js --plugin security --rule \"security/detect-object-injection:warn\" .",
    "test": "standard && npm run test:security && node -e \"require('./')\" && npm run test:ramdac && npm run test:hdd-security",
    "test:ramdac": "node test/ramdac.test.js",
    "test:hdd-security": "node test/hdd-security.test.js",
    "pack": "electron-builder --dir",
    "dist": "electron-builder",
    "security-audit": "npm audit && electron-builder --dir --config.nsis.oneClick=false",
    "build:secure": "npm run security-audit && npm run dist",
    "start:bot": "node bot.js",
    "start:node": "node get_top_music.js",
    "start:brass": "electron .",
    "debug:brass": "electron .",
    "start:fiddle": "electron . --fiddle",
    "debug:fiddle": "electron . --fiddle",
    "start:server": "node services/server.js"
  },
  "build": {
    "appId": "com.feross.lastfm",
    "productName": "LastFM Desktop",
    "forceCodeSigning": false,
    "directories": {
      "output": "dist"
    },
    "asar": true,
    "files": [
      "main.js",
      "preload.js",
      "index.html",
      "renderer.js",
      "styles.css",
      "assets/**/*",
      "fiddle-templates/**/*"
    ],
    "extraResources": [
      {
        "from": ".",
        "to": "resources",
        "filter": [
          "!**/.env",
          "!**/*.env",
          "!**/.env.example",
          "!**/certs/**/*"
        ]
      }
    ],
    "win": {
      "target": [
        "nsis"
      ],
      "signingHashAlgorithms": [
        "sha256"
      ]
    },
    "mac": {
      "target": [
        "dmg"
      ],
      "identity": "Developer ID Application: Your Name (TEAMID)"
    },
    "linux": {
      "target": [
        "AppImage"
      ]
    },
    "publish": {
      "provider": "generic",
      "url": "https://your-download-server.com/releases/"
    }
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "electron",
      "keytar"
    ]
  },
  "funding": [
    {
      "type": "github",
      "url": "https://github.com/sponsors/feross"
    },
    {
      "type": "patreon",
      "url": "https://www.patreon.com/feross"
    },
    {
      "type": "consulting",
      "url": "https://feross.org/support"
    }
  ]
}